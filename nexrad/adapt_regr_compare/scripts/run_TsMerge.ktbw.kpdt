#! /bin/csh -f

# Run Iq2Dsr, writing moments data to fmq

cd $HOME/git/lrose-test/nexrad/adapt_regr_compare/params

setenv radar_name kpdt
setenv RADAR_NAME KPDT
setenv CASE_DATE 20120423
setenv DATA_DIR /scr/cirrus1/rsfdata/projects/nexrad

snuff "TsMerge"
TsMerge -params TsMerge.ktbw.kpdt -clut_files /scr/cirrus1/rsfdata/projects/nexrad/time_series/kpdt/20120423/KPDT_RVP.20120423.200156.221.vcp12.1.H+V.460 /scr/cirrus1/rsfdata/projects/nexrad/time_series/kpdt/20120423/KPDT_RVP.20120423.200227.230.vcp12.3.H+V.460 -wx_files /scr/cirrus1/rsfdata/projects/nexrad/time_series/ktbw/20220928/KTBW.20220928.154934.566.vcp112.4.H+V.460 -debug


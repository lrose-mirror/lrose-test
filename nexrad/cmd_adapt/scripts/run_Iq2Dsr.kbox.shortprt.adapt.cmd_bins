#! /bin/csh -f

# Run Iq2Dsr, writing moments data to fmq

cd $HOME/git/lrose-test/nexrad/cmd_adapt/params

Dsr2Radx -params Dsr2Radx.kbox.shortprt.adapt.cmd_bins -debug >& /tmp/Dsr2Radx.kbox.shortprt.adapt.cmd_bins.log &
  Iq2Dsr -params Iq2Dsr.kbox.shortprt.adapt.cmd_bins -debug -f /scr/cirrus1/rsfdata/projects/nexrad/time_series/kbox/20240508/KBOX.20240508.132204.218.vcp212.13.H+V.137
  sleep 11
  snuff "Dsr2Radx -params Dsr2Radx.kbox.shortprt.adapt.cmd_bins"
end

